STRIPE_SECRET_KEY=sk_test_your_secret_key
STRIPE_PUBLISHABLE_KEY=pk_test_your_publishable_key
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
# Geocoding for proximity-based order routing.
# GEOCODER_PROVIDER options: photon | nominatim | opencage | google | mapbox
# photon (default) and nominatim both use OpenStreetMap data and need no key.
# photon (Komoot) has more lenient rate limits. Keyed providers require GEOCODER_API_KEY.
GEOCODER_PROVIDER=photon
GEOCODER_API_KEY=
PORT=8000
